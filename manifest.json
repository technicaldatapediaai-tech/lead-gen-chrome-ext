{
    "manifest_version": 3,
    "name": "Lead Genius LinkedIn Helper",
    "version": "1.1.0",
    "description": "Send LinkedIn outreach messages from Lead Genius - Auto-connects with web app",
    "permissions": [
        "storage",
        "activeTab",
        "tabs",
        "scripting",
        "declarativeNetRequest"
    ],
    "host_permissions": [
        "*://*.linkedin.com/*",
        "*://linkedin.com/*",
        "https://lead-gen-backend-dcxf.onrender.com/*",
        "https://lead-gen-frontend-orcin.vercel.app/*",
        "http://localhost:8000/*",
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "declarative_net_request" : {
        "rule_resources" : [{
          "id": "ruleset_1",
          "enabled": true,
          "path": "rules.json"
        }]
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["silencer.js"],
            "run_at": "document_start",
            "world": "MAIN",
            "all_frames": true,
            "match_about_blank": true
        },
        {
            "matches": [
                "*://*.linkedin.com/*",
                "*://linkedin.com/*",
                "https://lead-gen-frontend-orcin.vercel.app/*",
                "http://localhost:3000/*",
                "http://127.0.0.1:3000/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "content.css"
            ],
            "run_at": "document_idle",
            "all_frames": true
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}